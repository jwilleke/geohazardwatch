{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "dependencyDashboard": false,
  "timezone": "America/New_York",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Defer eslint major bumps until flat-config migration lands (jwilleke/geohazardwatch#43). Eslint 9+ requires eslint.config.js; the repo currently uses legacy .eslintrc.json. Remove this rule when the migration is done.",
      "matchPackageNames": ["eslint"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Auto-merge minor and patch updates for the ngdpbase base image",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/jwilleke/ngdpbase"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Major bumps of the ngdpbase base image require manual review",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["ghcr.io/jwilleke/ngdpbase"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-bump", "needs-review"]
    },
    {
      "description": "Auto-merge minor and patch npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true
    },
    {
      "description": "Major npm bumps require manual review",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-bump", "needs-review"]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  }
}
